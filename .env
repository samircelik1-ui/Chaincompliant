# --- Email (per ricevere notifica ad ogni richiesta) ---
# Se usi Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER = la tua email, SMTP_PASS = una "app password" (non la password normale).
# In alternativa usa un servizio come Resend, SendGrid, Mailgun: cambiano solo host/porta/credenziali.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuonome@gmail.com
SMTP_PASS=la_tua_app_password
SMTP_FROM=tuonome@gmail.com
NOTIFY_EMAIL_TO=dove-vuoi-ricevere-le-notifiche@example.com

# --- Provider AML (es. AMLBot) ---
# Prendi questi valori dalla dashboard del provider dopo la registrazione.
AML_API_URL=https://api.amlbot.com/DA-CONFERMARE-NELLA-LORO-DOCUMENTAZIONE
AML_API_KEY=il_tuo_token_api

PORT=3001
